# ═════════════════════════════════════════════════════════════
# Holisource WhatsApp Agent — Variables d'environnement
# ═════════════════════════════════════════════════════════════
# Copie ce fichier en .env et remplis les valeurs
# .env est dans .gitignore — jamais versionner les secrets

# ═════════════════════════════════════════════════════════════
# MISTRAL — API principale (IA conversationnelle)
# ═════════════════════════════════════════════════════════════
MISTRAL_API_KEY=...

# ═════════════════════════════════════════════════════════════
# SUPABASE — Base de données Holisource
# ═════════════════════════════════════════════════════════════
SUPABASE_URL=https://dqmujlqxpmcwscztrrdt.supabase.co
SUPABASE_KEY=eyJhbGc...

# ═════════════════════════════════════════════════════════════
# WHATSAPP PROVIDER — Choix du fournisseur
# ═════════════════════════════════════════════════════════════
WHATSAPP_PROVIDER=meta  # Options: meta | twilio

# ═════════════════════════════════════════════════════════════
# META CLOUD API — Si WHATSAPP_PROVIDER=meta
# ═════════════════════════════════════════════════════════════
# Récupère sur: https://developers.facebook.com
META_ACCESS_TOKEN=EAAx...
META_PHONE_NUMBER_ID=102...
META_VERIFY_TOKEN=holisource-verify-2026

# ═════════════════════════════════════════════════════════════
# TWILIO — Si WHATSAPP_PROVIDER=twilio
# ═════════════════════════════════════════════════════════════
# Récupère sur: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=ACx...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=whatsapp:+...

# ═════════════════════════════════════════════════════════════
# RESEND — Emails transactionnels
# ═════════════════════════════════════════════════════════════
RESEND_API_KEY=re_...

# ═════════════════════════════════════════════════════════════
# (Mistral API est configurée ci-dessus — elle gère aussi la modération)
# ═════════════════════════════════════════════════════════════

# ═════════════════════════════════════════════════════════════
# CALENDLY — Intégration agenda thérapeutes
# ═════════════════════════════════════════════════════════════
CALENDLY_API_KEY=...

# ═════════════════════════════════════════════════════════════
# SERVEUR
# ═════════════════════════════════════════════════════════════
PORT=8000
ENVIRONMENT=development  # development | production
